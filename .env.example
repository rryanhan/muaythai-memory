# Supabase public client values
# Safe to expose in frontend code when Row Level Security is configured.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database connection string for migrations/ORM.
# Keep this server-side only.
DATABASE_URL=
DATABASE_POOLER_URL=
DATABASE_DIRECT_URL=

# Supabase backend-only secret.
# Never expose this to frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Draft generation provider: ollama for free local development, openai for cloud use.
CAPTURE_DRAFT_PROVIDER=ollama

# Ollama runs locally and does not require an API key.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CAPTURE_MODEL=qwen3:4b-instruct

# OpenAI provider settings. Keep the API key server-side only.
OPENAI_API_KEY=
OPENAI_CAPTURE_MODEL=
