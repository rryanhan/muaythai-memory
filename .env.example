# Copy this template to .env.staging.local or
# .env.production-maintenance.local for hosted maintenance commands.
# APP_ENV_FILE selects one of those ignored files. The production maintenance
# name intentionally avoids Next.js's automatically loaded .env.production.local.
# Vercel should set the matching environment name in each project.
DEPLOYMENT_ENVIRONMENT=

# Supabase public Auth client values. These identifiers are intentionally
# browser-visible; product data still goes through authenticated Next APIs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Runtime traffic uses Supabase transaction pooling on port 6543. Keep the
# application-side pool at 1 on Vercel and 3 for local development.
DATABASE_POOLER_URL=
DATABASE_POOL_MAX=3

# Migrations use a direct connection on port 5432. DATABASE_URL remains only as
# a legacy fallback for local environments that have not renamed it yet.
DATABASE_DIRECT_URL=
DATABASE_URL=

# Canonical app origin used for auth origin checks, recovery callbacks, secure
# recovery cookies, and server-side API helpers. Set this explicitly on stable
# hosted deployments; proxy-forwarded host/protocol headers are never trusted.
# Vercel previews use trusted VERCEL_URL/VERCEL_BRANCH_URL system values instead.
# Only loopback development requests may fall back when this value is absent.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase backend-only secret.
# Never expose this to frontend code. It is also used by the one-time
# db:claim-dev-user command. This value must never be exposed to frontend code
# or committed with a real credential.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only HMAC key for short-lived authentication flow grants. Generate at
# least 32 random bytes independently in each environment. Never prefix this
# value with NEXT_PUBLIC_ or expose it to browser code.
AUTH_FLOW_SECRET=

# Draft generation provider: ollama for free local development, openai for cloud use.
CAPTURE_DRAFT_PROVIDER=ollama

# Ollama runs locally and does not require an API key.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CAPTURE_MODEL=qwen3:4b-instruct

# OpenAI provider settings. Keep the API key server-side only.
OPENAI_API_KEY=
OPENAI_CAPTURE_MODEL=

# Voice transcription. Use whisper-local for free local development and openai
# in hosted environments that cannot reach your computer's loopback address.
CAPTURE_TRANSCRIPTION_PROVIDER=whisper-local
WHISPER_SERVER_URL=http://127.0.0.1:8080/inference
WHISPER_MODEL_PATH=.local-models/ggml-small.en.bin
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
