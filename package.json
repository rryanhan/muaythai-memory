{
  "name": "muaythai-memory-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:describe": "python3 scripts/check_db_connection.py --env DATABASE_POOLER_URL --describe",
    "db:check": "python3 scripts/check_db_connection.py --env DATABASE_POOLER_URL",
    "db:preflight": "tsx src/db/preflight.ts",
    "db:verify-config": "tsx scripts/verify-database-config.ts",
    "db:verify-access-control": "tsx scripts/verify-database-access-control.ts",
    "db:verify-access-control:test": "tsx --test scripts/database-access-control-environment.test.ts",
    "env:verify:staging": "APP_ENV_FILE=.env.staging.local tsx scripts/verify-deployment-environment.ts --expect=staging",
    "env:verify:production": "APP_ENV_FILE=.env.production-maintenance.local tsx scripts/verify-deployment-environment.ts --expect=production",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:staging": "tsx scripts/migrate-database-environment.ts --environment=staging",
    "db:migrate:production": "tsx scripts/migrate-database-environment.ts --environment=production",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-drills": "tsx src/db/seed-dev-drills.ts",
    "db:claim-dev-user": "tsx src/db/claim-dev-user.ts",
    "db:verify-taxonomy": "tsx src/db/verify-taxonomy.ts",
    "db:verify-step3": "tsx src/db/verify-step3.ts",
    "api:verify": "tsx src/data/verify-api.ts",
    "auth:verify": "tsx src/db/verify-auth-ownership.ts",
    "auth:verify-api": "tsx src/data/verify-auth-api.ts",
    "auth:verify-recovery-grants": "tsx src/db/verify-auth-recovery-grants.ts",
    "onboarding:verify": "tsx src/modules/onboarding/verify-onboarding.ts",
    "capture:verify": "tsx src/modules/capture/verify-capture.ts",
    "profile:verify": "tsx src/modules/profile/verify-profile.ts",
    "journal:verify": "tsx src/modules/journal/verify-journal.ts",
    "journal:cleanup": "tsx scripts/cleanup-journal-uploads.ts",
    "journal:backfill-posters": "tsx scripts/backfill-journal-posters.ts",
    "storage:setup": "tsx scripts/setup-profile-storage.ts",
    "whisper:setup": "bash scripts/setup-local-whisper.sh",
    "whisper:serve": "bash scripts/start-local-whisper.sh"
  },
  "dependencies": {
    "@daypicker/react": "^10.0.1",
    "@fontsource/dseg7": "^4.5.4",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "latest",
    "@tanstack/react-query": "^5.101.2",
    "d3": "^7.9.0",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "next": "latest",
    "openai": "^6.46.0",
    "postgres": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-easy-crop": "^6.2.2",
    "tus-js-client": "^4.3.1",
    "vaul": "^1.1.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "drizzle-kit": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "^29.1.1",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^4.1.10"
  }
}
